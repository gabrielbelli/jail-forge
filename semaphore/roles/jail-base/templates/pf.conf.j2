# PF Configuration for Semaphore on BSD Jails
# Managed by Ansible - DO NOT EDIT MANUALLY

# Skip filtering on loopback
set skip on lo0

{% if jail_network_mode | default('alias') == 'nat' %}
# NAT mode: jails on {{ jail_nat_interface }} with NAT/port forwarding via {{ jail_interface }}

# NAT outbound traffic from jails
nat on {{ jail_interface }} from { {{ jail_ip_database }}, {{ jail_ip_semaphore }} } to any -> ({{ jail_interface }})

# Port forward: host:{{ semaphore_port }} -> semaphore jail
rdr on {{ jail_interface }} proto tcp to port {{ semaphore_port }} -> {{ jail_ip_semaphore }} port {{ semaphore_port }}

# Allow all outbound traffic
pass out quick on {{ jail_interface }} all

# Allow established connections
pass in quick on {{ jail_interface }} proto tcp flags S/SA keep state

# Allow SSH access (essential - do not remove!)
pass in on {{ jail_interface }} proto tcp to port 22

# Allow Semaphore web access (redirected to jail via rdr)
pass in on {{ jail_interface }} proto tcp to port {{ semaphore_port }}

# Allow all traffic on jail loopback (inter-jail communication)
pass on {{ jail_nat_interface }} all
{% else %}
# Alias mode: jails directly on {{ jail_interface }}

# Allow all outbound traffic
pass out quick on {{ jail_interface }} all

# Allow established connections
pass in quick on {{ jail_interface }} proto tcp flags S/SA keep state

# Allow SSH access (essential - do not remove!)
pass in on {{ jail_interface }} proto tcp to port 22

# Allow Semaphore web access
pass in on {{ jail_interface }} proto tcp to {{ jail_ip_semaphore }} port {{ semaphore_port }}

# Allow PostgreSQL access from Semaphore jail
pass in on {{ jail_interface }} proto tcp from {{ jail_ip_semaphore }} to {{ jail_ip_database }} port 5432

# Allow jails outbound access
pass out on {{ jail_interface }} from { {{ jail_ip_database }}, {{ jail_ip_semaphore }} }
{% endif %}
